@{
    var usuarioLogueado = Session["UsuarioLogueado"] as Capa2_Aplicacion.ModuloPrincipal.DTO.UsuarioDTO;
    var username = usuarioLogueado != null ? usuarioLogueado.Username : "admin";
    var isMedico = usuarioLogueado != null && usuarioLogueado.Rol == "Medico";
    var isRecepcionista = usuarioLogueado != null && usuarioLogueado.Rol == "Recepcionista";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Sistema de Gestión de Citas</title>
    <!-- Bootstrap 4.6.2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/Content/consultar-citas.css">
    @RenderSection("styles", required: false)
</head>
<body>
    <div class="container">
        <header>
            <h1>@ViewBag.HeaderTitle</h1>
            <nav style="margin-top: 10px; display: flex; gap: 10px; font-size: 14px; font-weight: 600;">
                <a href="@Url.Action("Index", "Home")" style="color: #3498DB; text-decoration: none;">🏠 Inicio</a>
                
                @if (isRecepcionista)
                {
                    <span style="color: #ccc;">|</span>
                    <a href="@Url.Action("PaginaRegistrarCita", "RegistrarCitas")" style="color: #3498DB; text-decoration: none;">📅 Registrar Cita</a>
                    <span style="color: #ccc;">|</span>
                    <a href="@Url.Action("PaginaGestionarPaciente", "GestionarPaciente")" style="color: #3498DB; text-decoration: none;">👥 Registrar y Gestionar Pacientes</a>
                }
                
                @if (isMedico)
                {
                    <span style="color: #ccc;">|</span>
                    <a href="@Url.Action("PaginaConsultarCitas", "ConsultarCitas")" style="color: #3498DB; text-decoration: none;">🔍 Consultar Citas</a>
                }
            </nav>
            <div class="usuario-info">
                <p>Usuario: <strong>@username</strong> @(usuarioLogueado != null ? $"({usuarioLogueado.Rol})" : "")</p>
                <a href="@Url.Action("CerrarSesion", "Login")" class="cerrarsesion-btn">Cerrar Sesión</a>
            </div>
        </header>

        <main>
            @RenderBody()
        </main>

        <footer>
            <p>&copy; @DateTime.Now.Year Sistema de Gestión de Citas Médicas. Trujillo, Perú.</p>
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap 4.6.2 Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>